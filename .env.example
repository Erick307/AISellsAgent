# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# LangSmith (observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Chatwoot
CHATWOOT_BASE_URL=https://your-chatwoot-instance.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_WEBHOOK_SECRET=your_webhook_secret
CHATWOOT_ACCOUNT_ID=1

# Google Drive (OAuth) — run `uv run python scripts/auth_google.py` once to generate token.json
GOOGLE_CREDENTIALS_PATH=credentials/credentials.json
GOOGLE_TOKEN_PATH=credentials/token.json

# Postgres
POSTGRES_URL=postgresql+asyncpg://aisales:aisales@localhost:5432/aisalesagent

# Agent behavior
MESSAGE_DEBOUNCE_SECONDS=3
ESCALATION_RESUME_HOURS=2

# ngrok (get your token free at https://dashboard.ngrok.com/get-started/your-authtoken)
# IMPORTANT: update CHATWOOT_FRONTEND_URL every time the ngrok URL changes (run `docker logs aisales_ngrok` to see it)
NGROK_AUTHTOKEN=your_ngrok_authtoken
CHATWOOT_FRONTEND_URL=https://your-ngrok-url.ngrok-free.dev
