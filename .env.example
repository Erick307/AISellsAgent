# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# LangSmith (observability)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key

# Chatwoot
CHATWOOT_BASE_URL=https://your-chatwoot-instance.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_WEBHOOK_SECRET=your_webhook_secret

# Google Drive (path to OAuth or Service Account JSON credentials file)
GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json

# Postgres
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/aisalesagent

# Agent behavior
MESSAGE_DEBOUNCE_SECONDS=3
